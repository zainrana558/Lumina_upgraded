# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# TMDB (server-only — never expose as NEXT_PUBLIC_)
TMDB_API_KEY=your_tmdb_api_key

# NexStream (server-only)
NEXSTREAM_API_KEY=your_nexstream_api_key

# Site URL for OAuth redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ==========================================
# PRODUCTION SECURITY (Recommended)
# ==========================================

# Upstash Redis for distributed rate limiting
# Get from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://yourDatabase.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXabc...

# Allowed Origins (comma-separated for production)
# e.g., https://lumina.yourdomain.com,https://www.lumina.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# Sentry for error monitoring (optional)
# Get from: https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=https://abc@sentry.io/123
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=your-auth-token
